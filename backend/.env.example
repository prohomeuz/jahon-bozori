# ── Jahon Bozori Backend — Environment Variables ─────────────────────────────
# Bu fayl TEMPLATE. Serverda bu faylni ko'chirib .env nomini bering:
#   cp backend/.env.example backend/.env
# Keyin haqiqiy qiymatlarni to'ldiring.

# Server port (Docker ichida o'zgartirmang)
PORT=3001

# JWT token imzolash kaliti — kamida 64 ta tasodifiy belgi
# Yangi kalit yaratish: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Telegram bot (bildirishnomalar uchun)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_ID_HERE

# AI xizmatlar (ixtiyoriy)
UV_KEY=
GPT_KEY=
